# Copy to .env and fill in values before running docker compose up

POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mediametrics

DATABASE_URL=postgresql+psycopg://app:changeme@db:5432/mediametrics

FRONTEND_ORIGIN=http://localhost:3000

# stub = hardcoded fake data, yt_dlp = real YouTube metrics
YOUTUBE_FETCHER_IMPL=stub

# URL the browser uses to reach the backend (host-facing, not Docker-internal)
NEXT_PUBLIC_API_BASE=http://localhost:8000
